# ─── Server ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Use * only for local dev — lock this down to your real domain in production.
# Example: ALLOWED_ORIGINS=https://meet.example.com,https://www.example.com
ALLOWED_ORIGINS=*

# ─── HTTPS ───────────────────────────────────────────────────────────────────
# Set HTTPS=true and provide cert paths to enable TLS directly on the server.
# In most cloud/container deployments TLS is terminated upstream (load balancer
# or reverse proxy), so leave HTTPS=false and omit the cert paths.
HTTPS=false
# SSL_KEY_PATH=/etc/ssl/private/server.key
# SSL_CERT_PATH=/etc/ssl/certs/server.crt
